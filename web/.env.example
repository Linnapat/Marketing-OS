# Marketing OS — environment
#
# The app runs entirely on typed mock data when these are empty, and
# transparently switches to the live database once they are set.
#
# Get these from your Supabase project → Settings → API.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER expose to the browser) — used by the one-time seed route
# and server-side writes. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Set to "true" to require login (Supabase Auth) before using the app.
# Leave empty/unset to keep the app open (gated only by Vercel protection).
# Turn this on only AFTER you've created at least one user + a matching row in
# the members table, or you'll lock yourself out.
NEXT_PUBLIC_REQUIRE_AUTH=
